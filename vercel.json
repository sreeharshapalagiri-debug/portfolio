{
  "version": 2,
  "builds": [
    {
      "src": "api/sendMail.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/sendMail",
      "dest": "/api/sendMail.js"
    }
  ]
}

{
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
